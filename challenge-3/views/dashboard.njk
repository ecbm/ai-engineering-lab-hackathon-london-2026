{% extends "layout.njk" %}

{% block content %}

  <h1 class="govuk-heading-l">Your cases</h1>

  {# Urgent notification banner #}
  {% if urgentCases.length > 0 %}
    <div class="app-notification-banner" role="alert" aria-label="Urgent cases requiring attention">
      <div class="app-notification-banner__header">Action required</div>
      <div class="app-notification-banner__body">
        <p><strong>{{ urgentCases.length }} {% if urgentCases.length == 1 %}case needs{% else %}cases need{% endif %} urgent attention:</strong></p>
        <ul class="govuk-list govuk-list--bullet">
          {% for c in urgentCases %}
            <li>
              <a href="/case/{{ c.case_id }}" class="govuk-link">{{ c.case_id }}</a> —
              {% if c.status == 'escalated' and c.escalationStatus %}
                evidence overdue by {{ c.escalationStatus.days }} days, already escalated
              {% elif c.escalationStatus %}
                evidence overdue by {{ c.escalationStatus.days }} days, escalation threshold breached
              {% else %}
                case escalated
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  {% endif %}

  {# Stats row #}
  <div class="app-stats-row" role="region" aria-label="Case summary statistics">
    <div class="app-stat-box">
      <div class="app-stat-box__number">{{ stats.total }}</div>
      <div class="app-stat-box__label">Total cases</div>
    </div>
    <div class="app-stat-box app-stat-box--red">
      <div class="app-stat-box__number">{{ stats.escalated }}</div>
      <div class="app-stat-box__label">Escalated</div>
    </div>
    <div class="app-stat-box app-stat-box--orange">
      <div class="app-stat-box__number">{{ stats.awaiting_evidence }}</div>
      <div class="app-stat-box__label">Awaiting evidence</div>
    </div>
    <div class="app-stat-box app-stat-box--green">
      <div class="app-stat-box__number">{{ stats.closed }}</div>
      <div class="app-stat-box__label">Closed</div>
    </div>
  </div>

  {# Filters #}
  <form class="app-filter-bar" method="get" action="/" role="search" aria-label="Filter cases">
    <label class="app-filter-bar__field">
      Search
      <input class="govuk-input" type="text" name="search" value="{{ filters.search }}"
        placeholder="Name, case ID or reference" aria-label="Search by name, case ID or reference">
    </label>
    <label class="app-filter-bar__field">
      Status
      <select class="govuk-select" name="status" aria-label="Filter by status">
        <option value="">All statuses</option>
        <option value="awaiting_evidence" {% if filters.status == 'awaiting_evidence' %}selected{% endif %}>Awaiting evidence</option>
        <option value="under_review" {% if filters.status == 'under_review' %}selected{% endif %}>Under review</option>
        <option value="pending_decision" {% if filters.status == 'pending_decision' %}selected{% endif %}>Pending decision</option>
        <option value="escalated" {% if filters.status == 'escalated' %}selected{% endif %}>Escalated</option>
        <option value="closed" {% if filters.status == 'closed' %}selected{% endif %}>Closed</option>
      </select>
    </label>
    <label class="app-filter-bar__field">
      Case type
      <select class="govuk-select" name="case_type" aria-label="Filter by case type">
        <option value="">All types</option>
        <option value="benefit_review" {% if filters.case_type == 'benefit_review' %}selected{% endif %}>Benefit review</option>
        <option value="licence_application" {% if filters.case_type == 'licence_application' %}selected{% endif %}>Licence application</option>
        <option value="compliance_check" {% if filters.case_type == 'compliance_check' %}selected{% endif %}>Compliance check</option>
      </select>
    </label>
    <button type="submit" class="govuk-button govuk-!-margin-bottom-0 app-filter-bar__button" data-module="govuk-button">Apply filters</button>
    {% if filters.search or filters.status or filters.case_type %}
      <a href="/" class="govuk-link govuk-body-s app-filter-bar__clear">Clear filters</a>
    {% endif %}
  </form>

  {# Result count #}
  <p class="govuk-body-s govuk-!-margin-bottom-2" aria-live="polite" aria-atomic="true">
    Showing {{ resultCount }} {% if resultCount == 1 %}case{% else %}cases{% endif %}
    {% if filters.search or filters.status or filters.case_type %} (filtered){% endif %}
  </p>

  {# Case table #}
  {% if cases.length > 0 %}
    <table class="govuk-table" aria-label="Case list">
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Case ID</th>
          <th scope="col" class="govuk-table__header">Applicant</th>
          <th scope="col" class="govuk-table__header">Type</th>
          <th scope="col" class="govuk-table__header">Status</th>
          <th scope="col" class="govuk-table__header">Last updated</th>
          <th scope="col" class="govuk-table__header">Days since update</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for c in cases %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a href="/case/{{ c.case_id }}" class="govuk-link govuk-link--no-visited-state">{{ c.case_id }}</a>
            </td>
            <td class="govuk-table__cell">{{ c.applicant.name }}</td>
            <td class="govuk-table__cell">{{ c.case_type | caseTypeLabel }}</td>
            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ c.status | statusTagClass }}">{{ c.status | statusLabel }}</strong>
            </td>
            <td class="govuk-table__cell">{{ c.last_updated | formatDate }}</td>
            <td class="govuk-table__cell">
              <span class="app-days-badge {{ c.daysBadge.cssClass }}">{{ c.daysBadge.label }}</span>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="govuk-body">No cases match your filters.</p>
  {% endif %}

{% endblock %}
