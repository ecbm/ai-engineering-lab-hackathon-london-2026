<!DOCTYPE html>
<html lang="en" class="govuk-template">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#1d70b8">
    <title>{{ title }}</title>
    <link rel="icon" sizes="48x48" href="/assets/images/favicon.ico">
    <link rel="stylesheet" href="/govuk-frontend.min.css">
    <link rel="stylesheet" href="/public/css/app.css">
  </head>
  <body class="govuk-template__body">
    <script>document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');</script>

    <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>

    <header class="govuk-header" data-module="govuk-header" role="banner">
      <div class="govuk-header__container govuk-width-container">
        <div class="govuk-header__logo">
          <a href="/" class="govuk-header__link govuk-header__link--homepage">
            <span class="govuk-header__logotype-text">CaseTracker</span>
          </a>
        </div>
        <div class="govuk-header__content">
          <nav aria-label="Main navigation" class="govuk-header__navigation">
            <ul class="govuk-header__navigation-list">
              <li class="govuk-header__navigation-item {% if activePage == 'dashboard' %}govuk-header__navigation-item--active{% endif %}">
                <a class="govuk-header__link" href="/" {% if activePage == 'dashboard' %}aria-current="page"{% endif %}>Dashboard</a>
              </li>
              <li class="govuk-header__navigation-item {% if activePage == 'team-leader' %}govuk-header__navigation-item--active{% endif %}">
                <a class="govuk-header__link" href="/team" {% if activePage == 'team-leader' %}aria-current="page"{% endif %}>Team view</a>
              </li>
              <li class="govuk-header__navigation-item {% if activePage == 'applicant' %}govuk-header__navigation-item--active{% endif %}">
                <a class="govuk-header__link" href="/applicant" {% if activePage == 'applicant' %}aria-current="page"{% endif %}>Applicant portal</a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <div class="govuk-width-container">
      {% block beforeContent %}{% endblock %}
      <main class="govuk-main-wrapper {% block mainClass %}{% endblock %}" id="main-content" role="main">
        {% block content %}{% endblock %}
      </main>
    </div>

    <footer class="govuk-footer" role="contentinfo">
      <div class="govuk-width-container">
        <div class="govuk-footer__meta">
          <div class="govuk-footer__meta-item govuk-footer__meta-item--grow">
            <span class="govuk-footer__licence-description">
              Hackathon prototype — Challenge 3: Supporting casework decisions
            </span>
          </div>
        </div>
      </div>
    </footer>

    <script src="/govuk-frontend.bundle.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        if (window.GOVUKFrontend) {
          window.GOVUKFrontend.initAll();
        }
      });
    </script>
  </body>
</html>
