<!DOCTYPE html>
<html lang="en" class="govuk-template">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#0b0c0c">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/govuk-frontend.min.css">
    <link rel="stylesheet" href="/public/css/app.css">
  </head>
  <body class="govuk-template__body">
    <script>
      document.body.className = ((document.body.className) ? document.body.className + ' js-enabled' : 'js-enabled');
    </script>

    <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>

    <header class="govuk-header" role="banner" data-module="govuk-header">
      <div class="govuk-header__container govuk-width-container">
        <div class="govuk-header__logo">
          <a href="/" class="govuk-header__link govuk-header__link--homepage">
            <span class="govuk-header__logotype">
              <span class="govuk-header__logotype-text">GOV.UK</span>
            </span>
          </a>
        </div>
        <div class="govuk-header__content">
          <a href="/" class="govuk-header__link govuk-header__link--service-name">
            CaseTracker
          </a>
          <nav aria-label="Menu" class="govuk-header__navigation">
            <ul class="govuk-header__navigation-list">
              <li class="govuk-header__navigation-item {% if activePage == 'dashboard' %}govuk-header__navigation-item--active{% endif %}">
                <a class="govuk-header__link" href="/">Dashboard</a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <div class="govuk-width-container">
      <main class="govuk-main-wrapper" id="main-content" role="main">
        {% block content %}{% endblock %}
      </main>
    </div>

    <footer class="govuk-footer" role="contentinfo">
      <div class="govuk-width-container">
        <div class="govuk-footer__meta">
          <div class="govuk-footer__meta-item govuk-footer__meta-item--grow">
            <h2 class="govuk-visually-hidden">Support links</h2>
            <span class="govuk-footer__licence-description">
              CaseTracker — Hackathon prototype. Not for production use.
            </span>
          </div>
        </div>
      </div>
    </footer>

    <script src="/govuk-frontend.bundle.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        if (window.GOVUKFrontend) {
          window.GOVUKFrontend.initAll();
        }
      });
    </script>
  </body>
</html>
