{% extends "layout.njk" %}

{% block beforeContent %}
  <a href="{{ backLink }}" class="govuk-back-link">Back to cases</a>
{% endblock %}

{% block content %}

  <span class="govuk-caption-l">{{ case.case_id }} &middot; {{ caseTypeLabel }}</span>
  <h1 class="govuk-heading-l">
    {{ case.applicant.name }}
    <strong class="govuk-tag {{ case.status | statusTagClass }}">{{ case.status | statusLabel }}</strong>
  </h1>

  {# Escalation alert #}
  {% if case.escalationStatus and case.escalationStatus.status != 'ok' %}
    <div class="app-warning-callout app-warning-callout--urgent" role="alert" aria-label="Urgent warning">
      <p class="app-warning-callout__title">
        {% if case.escalationStatus.status == 'overdue' %}
          Evidence overdue — {{ case.escalationStatus.days }} days outstanding
        {% else %}
          Evidence reminder due — {{ case.escalationStatus.days }} days outstanding
        {% endif %}
      </p>
      <p>
        Evidence requested on {{ case.escalationStatus.evidenceRequestedDate | formatDate }}.
        {% if case.escalationStatus.status == 'overdue' %}
          {{ case.escalationStatus.escalationDays }}-day escalation threshold breached.
          Reminder should have been sent at {{ case.escalationStatus.reminderDays }} days.
        {% else %}
          {{ case.escalationStatus.reminderDays }}-day reminder threshold reached.
        {% endif %}
      </p>
    </div>
  {% endif %}

  {# AI summary #}
  {% if aiSummary %}
    <section class="app-ai-summary" aria-label="AI-generated case summary">
      <p class="app-ai-summary__label">AI-generated summary</p>
      <p class="govuk-body govuk-!-margin-bottom-0">{{ aiSummary }}</p>
    </section>
  {% endif %}

  {# Workflow tracker #}
  <h2 class="govuk-heading-m">Workflow</h2>
  <ol class="app-workflow-tracker" aria-label="Case workflow progress">
    {% for step in workflowSteps %}
      <li class="app-workflow-tracker__step app-workflow-tracker__step--{{ step.stepStatus }}"
        {% if step.stepStatus == 'current' %}aria-current="step"{% endif %}
        {% if step.stepStatus == 'future' %}aria-disabled="true"{% endif %}>
        {{ step.label }}
        {% if step.stepStatus == 'completed' %}<span class="govuk-visually-hidden">(completed)</span>{% endif %}
      </li>
    {% endfor %}
  </ol>

  <div class="govuk-grid-row">

    {# Main column #}
    <div class="govuk-grid-column-two-thirds">

      {# Required actions #}
      <fieldset class="app-actions-fieldset">
        <legend class="govuk-heading-m">Required actions</legend>
        <div class="app-actions-list">
          {% for item in requiredActions %}
            <label class="app-action-label {% if loop.last %}app-action-label--last{% endif %}">
              <input type="checkbox" {% if item.completed %}checked{% endif %}
                aria-describedby="action-{{ loop.index }}-desc">
              <span id="action-{{ loop.index }}-desc" {% if item.completed %}class="app-action-completed"{% endif %}>
                <strong>{{ item.action }}</strong>
                {% if item.completed %}<span class="govuk-visually-hidden">(completed)</span>{% endif %}
              </span>
            </label>
          {% endfor %}
        </div>
      </fieldset>

      {# Timeline #}
      <h2 class="govuk-heading-m govuk-!-margin-top-6">Case timeline</h2>
      <ol class="app-timeline" aria-label="Case event timeline">
        {% for event in timeline %}
          <li class="app-timeline__event {% if event.event == 'case_created' %}app-timeline__event--success{% endif %}">
            <time class="app-timeline__date" datetime="{{ event.date }}">
              {{ event.date | formatDate }}
            </time>
            <p class="app-timeline__title">{{ event.event | eventLabel }}</p>
            {% if event.note %}
              <p class="app-timeline__description">{{ event.note }}</p>
            {% endif %}
          </li>
        {% endfor %}
      </ol>

      {# Case notes #}
      <h2 class="govuk-heading-m govuk-!-margin-top-6">Case notes</h2>
      <div class="govuk-inset-text">
        <p>{{ case.case_notes }}</p>
      </div>
      <button type="button" class="govuk-button govuk-button--secondary" data-module="govuk-button">Add case note</button>

    </div>

    {# Sidebar #}
    <div class="govuk-grid-column-one-third">

      {# Applicant details #}
      <h2 class="govuk-heading-s">Applicant details</h2>
      <dl class="govuk-summary-list govuk-!-margin-bottom-6">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Name</dt>
          <dd class="govuk-summary-list__value">{{ case.applicant.name }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Reference</dt>
          <dd class="govuk-summary-list__value">{{ case.applicant.reference }}</dd>
        </div>
        {% if case.applicant.date_of_birth %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Date of birth</dt>
            <dd class="govuk-summary-list__value">{{ case.applicant.date_of_birth | formatDate }}</dd>
          </div>
        {% endif %}
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Team</dt>
          <dd class="govuk-summary-list__value">{{ case.assigned_to | teamLabel }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Created</dt>
          <dd class="govuk-summary-list__value">{{ case.created_date | formatDate }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Updated</dt>
          <dd class="govuk-summary-list__value">{{ case.last_updated | formatDate }}</dd>
        </div>
      </dl>

      {# Evidence tracker #}
      {% if evidenceItems.length > 0 %}
        <h2 class="govuk-heading-s">Evidence tracker</h2>
        <table class="govuk-table govuk-!-margin-bottom-6" aria-label="Evidence status">
          <thead class="govuk-visually-hidden">
            <tr>
              <th scope="col" class="govuk-table__header">Document</th>
              <th scope="col" class="govuk-table__header">Status</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for item in evidenceItems %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ item.label }}</td>
                <td class="govuk-table__cell">
                  <strong class="govuk-tag {{ item.statusClass }}">{{ item.statusLabel }}</strong>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}

      {# Applicable policies #}
      {% if applicablePolicies.length > 0 %}
        <h2 class="govuk-heading-s">Applicable policies</h2>
        {% for policy in applicablePolicies %}
          <details class="govuk-details" {% if loop.index == 3 %}open{% endif %}>
            <summary class="govuk-details__summary">
              <span class="govuk-details__summary-text">{{ policy.policy_id }} — {{ policy.title }}</span>
            </summary>
            <div class="govuk-details__text">{{ policy.body }}</div>
          </details>
        {% endfor %}
      {% endif %}

      {# Quick actions #}
      <h2 class="govuk-heading-s govuk-!-margin-top-5">Quick actions</h2>
      <button type="button" class="govuk-button govuk-!-width-full" data-module="govuk-button">Escalate case</button>
      <button type="button" class="govuk-button govuk-button--secondary govuk-!-width-full" data-module="govuk-button">Send reminder</button>
      <button type="button" class="govuk-button govuk-button--secondary govuk-!-width-full" data-module="govuk-button">Record evidence</button>

    </div>

  </div>

{% endblock %}
