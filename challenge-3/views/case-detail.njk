{% extends "layout.njk" %}

{% block content %}

  <a href="{{ backLink }}" class="govuk-back-link">Back to cases</a>

  <span class="govuk-caption-l">{{ case.case_id }} &middot; {{ caseTypeLabel }}</span>
  <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">
    {{ case.applicant.name }}
    <strong class="govuk-tag {{ case.status | statusTagClass }} govuk-!-margin-left-2">{{ case.status | statusLabel }}</strong>
  </h1>

  {# Workflow tracker #}
  <nav aria-label="Workflow progress" class="app-workflow-tracker govuk-!-margin-bottom-6">
    <ol class="app-workflow-tracker__steps" role="list">
      {% for step in workflowSteps %}
        <li class="app-workflow-tracker__step app-workflow-tracker__step--{{ step.stepStatus }}"
          {% if step.stepStatus == 'current' %}aria-current="step"{% endif %}
          {% if step.stepStatus == 'future' %}aria-disabled="true"{% endif %}>
          {{ step.label }}
        </li>
      {% endfor %}
    </ol>
  </nav>

  {# Two-column layout #}
  <div class="govuk-grid-row">

    {# Main column — 2/3 width #}
    <div class="govuk-grid-column-two-thirds">

      {# Escalation alert banner #}
      {% if case.escalationStatus and case.escalationStatus.status != 'ok' %}
        <div class="app-alert-banner app-alert-banner--{{ case.escalationStatus.status }}" role="alert">
          <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">
            {% if case.escalationStatus.status == 'overdue' %}
              Evidence overdue — {{ case.escalationStatus.days }} days outstanding
            {% else %}
              Evidence reminder due — {{ case.escalationStatus.days }} days outstanding
            {% endif %}
          </p>
          <p class="govuk-body-s govuk-!-margin-bottom-0">
            Evidence requested on {{ case.escalationStatus.evidenceRequestedDate | formatDate }}.
            {% if case.escalationStatus.status == 'overdue' %}
              {{ case.escalationStatus.escalationDays }}-day escalation threshold breached.
              Reminder should have been sent at {{ case.escalationStatus.reminderDays }} days.
            {% else %}
              {{ case.escalationStatus.reminderDays }}-day reminder threshold reached.
            {% endif %}
          </p>
        </div>
      {% endif %}

      {# AI-generated summary #}
      {% if aiSummary %}
        <div class="app-ai-summary" aria-labelledby="ai-summary-label">
          <span class="app-ai-summary__label" id="ai-summary-label" aria-hidden="true">AI-generated summary</span>
          <span class="govuk-visually-hidden">AI-generated summary: </span>
          <p class="govuk-body govuk-!-margin-bottom-0">{{ aiSummary }}</p>
        </div>
      {% endif %}

      {# Required actions #}
      <fieldset class="govuk-fieldset app-actions-fieldset">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
          <h2 class="govuk-fieldset__heading">Required actions</h2>
        </legend>
        <div class="govuk-checkboxes govuk-checkboxes--small">
          {% for item in requiredActions %}
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="action-{{ loop.index }}" name="actions"
                type="checkbox" value="{{ loop.index }}"
                {% if item.completed %}checked{% endif %}
                aria-label="{{ item.action }}">
              <label class="govuk-label govuk-checkboxes__label {% if item.completed %}app-action--completed{% endif %}"
                for="action-{{ loop.index }}">
                {{ item.action }}
              </label>
            </div>
          {% endfor %}
        </div>
      </fieldset>

      {# Case timeline #}
      <h2 class="govuk-heading-m govuk-!-margin-top-6">Case timeline</h2>
      <ol class="app-timeline" aria-label="Case timeline events">
        {% for event in timeline %}
          <li class="app-timeline__event">
            <div class="app-timeline__bullet {% if event.event == 'case_created' %}app-timeline__bullet--green{% else %}app-timeline__bullet--blue{% endif %}"></div>
            <div class="app-timeline__content">
              <time class="app-timeline__date govuk-body-s" datetime="{{ event.date }}">
                {{ event.date | formatDate }}
              </time>
              <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">
                {{ event.event | eventLabel }}
              </p>
              {% if event.note %}
                <p class="govuk-body-s govuk-!-margin-bottom-0 app-timeline__note">{{ event.note }}</p>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ol>

      {# Case notes #}
      <h2 class="govuk-heading-m govuk-!-margin-top-6">Case notes</h2>
      <div class="govuk-inset-text">
        <p class="govuk-body govuk-!-margin-bottom-2">{{ case.case_notes }}</p>
      </div>
      <button type="button" class="govuk-button govuk-button--secondary">Add case note</button>

    </div>{# end main column #}

    {# Sidebar — 1/3 width #}
    <div class="govuk-grid-column-one-third">

      {# Applicant details #}
      <h2 class="govuk-heading-s">Applicant details</h2>
      <dl class="govuk-summary-list govuk-summary-list--no-border govuk-!-margin-bottom-6">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Name</dt>
          <dd class="govuk-summary-list__value">{{ case.applicant.name }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Reference</dt>
          <dd class="govuk-summary-list__value">{{ case.applicant.reference }}</dd>
        </div>
        {% if case.applicant.date_of_birth %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Date of birth</dt>
            <dd class="govuk-summary-list__value">{{ case.applicant.date_of_birth | formatDate }}</dd>
          </div>
        {% endif %}
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Team</dt>
          <dd class="govuk-summary-list__value">{{ case.assigned_to | teamLabel }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Opened</dt>
          <dd class="govuk-summary-list__value">{{ case.created_date | formatDate }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Updated</dt>
          <dd class="govuk-summary-list__value">{{ case.last_updated | formatDate }}</dd>
        </div>
      </dl>

      {# Evidence tracker #}
      {% if evidenceItems.length > 0 %}
        <h2 class="govuk-heading-s">Evidence tracker</h2>
        <table class="govuk-table govuk-!-margin-bottom-6" aria-label="Evidence status">
          <caption class="govuk-visually-hidden">Evidence items and their current status</caption>
          <tbody class="govuk-table__body">
            {% for item in evidenceItems %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-body-s">{{ item.label }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  <strong class="govuk-tag {{ item.statusClass }}">{{ item.statusLabel }}</strong>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}

      {# Applicable policies #}
      {% if applicablePolicies.length > 0 %}
        <h2 class="govuk-heading-s">Applicable policies</h2>
        <div class="app-policies govuk-!-margin-bottom-6">
          {% for policy in applicablePolicies %}
            <details class="govuk-details app-policy-details" {% if loop.index == 3 %}open{% endif %}>
              <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">
                  {{ policy.policy_id }} — {{ policy.title }}
                </span>
              </summary>
              <div class="govuk-details__text govuk-body-s">
                {{ policy.body }}
              </div>
            </details>
          {% endfor %}
        </div>
      {% endif %}

      {# Quick actions #}
      <h2 class="govuk-heading-s">Quick actions</h2>
      <div class="app-quick-actions">
        <button type="button" class="govuk-button govuk-button--warning app-quick-actions__btn">
          Escalate case
        </button>
        <button type="button" class="govuk-button govuk-button--secondary app-quick-actions__btn">
          Send reminder
        </button>
        <button type="button" class="govuk-button govuk-button--secondary app-quick-actions__btn">
          Record evidence
        </button>
      </div>

    </div>{# end sidebar #}

  </div>{# end grid row #}

{% endblock %}
